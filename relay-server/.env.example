# ── LLM API ──────────────────────────────────────────────────────────────────
# Anthropic example:
BOT_API_URL=https://api.anthropic.com/v1/messages
BOT_API_KEY=sk-ant-...
BOT_MODEL=claude-opus-4-5

# OpenAI example:
# BOT_API_URL=https://api.openai.com/v1/chat/completions
# BOT_API_KEY=sk-...
# BOT_MODEL=gpt-4o

# Local Ollama example:
# BOT_API_URL=http://localhost:11434/v1/chat/completions
# BOT_API_KEY=ollama
# BOT_MODEL=gpt-oss:20b

# ── Win98 TCP listener ───────────────────────────────────────────────────────
# Win98 agent connects outbound to this port
WIN98_LISTEN_PORT=9000
WIN98_LISTEN_HOST=0.0.0.0

# ── HTTP server (VB6 GUI connects here) ──────────────────────────────────────
HTTP_PORT=3000
HTTP_HOST=0.0.0.0

# ── File staging ──────────────────────────────────────────────────────────────
STAGING_DIR=./staging_data

# ── SQLite (leave blank or omit to use in-memory only) ───────────────────────
DB_PATH=./win98botter.db

# ── Context management ────────────────────────────────────────────────────────
SESSION_CONTEXT_TOKEN_BUDGET=80000

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── Watchdog / alerting ───────────────────────────────────────────────────────
# POST alerts here (Slack, Discord, n8n, etc.) — leave empty to disable
ALERT_WEBHOOK_URL=
# Seconds of silence before "disconnected_presumed"
HEARTBEAT_TIMEOUT_SEC=300
# How often the watchdog loop fires
WATCHDOG_INTERVAL_SEC=30
# Optional automated health check schedule
HEALTHCHECKS_PATH=./healthchecks.json

# ── Phase 1 map cache (PostgreSQL) ───────────────────────────────────────────
# Optional feature. Enable persistent per-agent map cache (directory map,
# file-read captures, registry map). Existing chat/session history still uses
# SQLite.
# Set to 1 to enable, or 0 to disable.
PHASE1_PG_ENABLED=1
PHASE1_PG_HOST=postgres
PHASE1_PG_PORT=5432
PHASE1_PG_DATABASE=win98botter
PHASE1_PG_USER=win98botter
PHASE1_PG_PASSWORD=win98botter
PHASE1_PG_SSL=0
# Optional full URL (overrides host/port/db/user/pass when provided):
# PHASE1_PG_URL=postgresql://win98botter:win98botter@postgres:5432/win98botter
