# Win98 Botter — Relay Server configuration
# Edit these values in the web GUI (http://localhost:3000) on first run,
# or fill them in here before starting with docker compose up --build.

# LLM provider
# Ollama (Docker):   http://host.docker.internal:11434/v1
# Ollama (bare-metal): http://localhost:11434/v1
# Anthropic:         https://api.anthropic.com/v1
# OpenAI:            https://api.openai.com/v1
BOT_API_URL=
BOT_API_KEY=
BOT_MODEL=

# Network ports (inside the container — map these in docker-compose.yml)
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
WIN98_LISTEN_PORT=9000
WIN98_LISTEN_HOST=0.0.0.0

# Logging: trace | debug | info | warn | error
LOG_LEVEL=info

# How many tokens of conversation history to keep per session
SESSION_CONTEXT_TOKEN_BUDGET=80000
